# Google Tag Manager container ID (e.g. GTM-XXXXXXX).
# GA4 and Meta Pixel are configured as tags *inside* this GTM container,
# not as separate env vars — see the Analytics section of tech.md.
# Leave unset locally and the site runs with zero tracking/scripts.
NEXT_PUBLIC_GTM_ID=

# Brevo (email) API key — Account > SMTP & API > API Keys in Brevo.
# Used by /api/newsletter to add signups to a list and send the coupon email.
# Leave unset locally and the newsletter form fails gracefully (503).
BREVO_API_KEY=

# Numeric ID of the Brevo contact list signups should be added to
# (Contacts > Lists > your list > the number in the URL/list details).
BREVO_LIST_ID=
